# Copy this file to .env to override defaults.
# All variables below are optional for local Docker development —
# docker-compose.yml provides safe defaults so `docker compose up --build`
# works without any configuration.

# Secret key for JWT signing.
# A default dev value is set in docker-compose.yml.
# Generate a real one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Base URL the browser uses to reach the backend API.
# Defaults to http://localhost:8000 — only change if you remap the backend port.
VITE_API_URL=http://localhost:8000
